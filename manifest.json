{
  "manifest_version": 3,
  "name": "Anti-Ragging College Picker & Auto-Filler",
  "version": "2.0",
  "description": "An advanced search extension to easily find your college, plus instantly auto-fill and save your anti-ragging forms.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "College Picker & Auto-Filler",
    "default_icon": "assets/CollegeFinderIcon.png"
  },
  "icons": {
    "16": "assets/CollegeFinderIcon.png",
    "48": "assets/CollegeFinderIcon.png",
    "128": "assets/CollegeFinderIcon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://antiragging.in/*",
        "https://www.antiragging.in/*"
      ],
      "js": ["src/content.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
