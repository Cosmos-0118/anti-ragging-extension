{
  "manifest_version": 3,
  "name": "Anti-Ragging College Picker",
  "version": "1.0",
  "description": "An advanced search extension to easily find and select your college on the anti-ragging website.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "College Picker"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
